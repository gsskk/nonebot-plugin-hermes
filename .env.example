# ============================================================
# NoneBot 基础配置
# ============================================================

DRIVER=~fastapi
HOST=127.0.0.1
PORT=8080
COMMAND_START=["/"]
COMMAND_SEP=["."]

# ============================================================
# 适配器配置（根据你使用的 adapter 选择配置）
# ============================================================

# --- OneBot v11 (NapCatQQ, LLOneBot, go-cqhttp 等) ---
# 方式一：正向 WebSocket（NoneBot 主动连接 OneBot 实现端）
ONEBOT_WS_URLS=["ws://127.0.0.1:3001"]
# ONEBOT_ACCESS_TOKEN=

# 方式二：反向 WebSocket（OneBot 实现端主动连接 NoneBot）
# 注释掉上方 ONEBOT_WS_URLS，将 HOST 改为 0.0.0.0，
# 然后在 NapCatQQ/LLOneBot 中配置反向 WS 地址为:
#   ws://<NoneBot IP>:<PORT>/onebot/v11/ws

# --- QQ Official Bot ---
# QQ_BOTS='[{"id":"xxx","token":"xxx","secret":"xxx","intent":{"at_messages":true}}]'

# ============================================================
# Hermes Agent 配置
# ============================================================

# Hermes API Server 地址（对应 hermes gateway 的 api_server 端口）
HERMES_API_URL=http://127.0.0.1:8642

# Hermes API Key（需与 ~/.hermes/.env 中的 API_SERVER_KEY 一致）
# 生成命令: python -c "import secrets; print(secrets.token_hex(32))" 或 openssl rand -hex 32
HERMES_API_KEY=

# API 超时时间（秒），Agent 执行工具可能较慢
HERMES_API_TIMEOUT=300

# ============================================================
# 触发模式
# ============================================================

# 群聊触发方式: at / all / keyword
HERMES_GROUP_TRIGGER=at

# keyword 模式下的触发关键词（JSON 数组）
# HERMES_KEYWORDS=["/ai", "小助手"]

# 私聊触发方式: all / allowlist
HERMES_PRIVATE_TRIGGER=all

# 允许私聊的用户 ID（allowlist 模式，JSON 数组）
# HERMES_ALLOW_USERS=["12345678"]

# 允许响应的群组 ID（空 = 全部允许，JSON 数组）
# HERMES_ALLOW_GROUPS=["987654321"]

# 管理员白名单，格式 "<adapter>:<user_id>"，adapter 取小写+去空格点
# (telegram / onebotv11 / discord / kook / ...)。默认空集 = deny by default,
# /hermes-status 等敏感命令必须命中才会执行。
# HERMES_ADMIN_USERS=["telegram:7055555877", "onebotv11:12345678"]

# ============================================================
# 会话设置
# ============================================================

# 群内是否共享 session（false = 每人独立对话）
HERMES_SESSION_SHARE_GROUP=false

# ============================================================
# 消息设置
# ============================================================

# 单条回复最大长度（QQ 限制约 4500 字符）
HERMES_MAX_LENGTH=4000

# 以这些字符开头的消息不触发回复（JSON 数组）
HERMES_IGNORE_PREFIX=["."]

# ============================================================
# 被动感知 (Chat Awareness)
# ============================================================

# 是否开启被动感知:在群聊 + active_session=false 下,@bot 时给 LLM 注入
# 旁观历史(其他人之前在群里聊了什么)。私聊不注入——Hermes session 已覆盖。
# 注意:HERMES_ACTIVE_SESSION_ENABLED=true 时被动感知自动隐含为 on,本开关无效。
HERMES_PERCEPTION_ENABLED=false

# 被动感知缓存的历史消息数量
HERMES_PERCEPTION_BUFFER=10

# 被动感知单条历史消息最大长度（超出截断）
HERMES_PERCEPTION_TEXT_LENGTH=200

# 历史记录中的图片处理模式:
#   placeholder      历史里图只用 [图片] 占位 + URL 引用,多模态 content 只发当前图(默认,推荐)
#   inline_labeled   历史最后一张图带 <<HISTORICAL IMAGES>> 标签随多模态发送,与当前图清晰分隔
#                    适合需要"对比这张和上一张图"等跨图诉求的场景
#   none             完全不提历史图
HERMES_PERCEPTION_IMAGE_MODE=placeholder

# ============================================================
# M1 — 群活跃态 (实验性)
# ============================================================

# 启用后,@bot 触发后 5 分钟内 bot 会监听话题相关消息并按需主动插话。
# 关闭(默认)则退化为 v0.1.6 等价行为(只有显式触发才回复)。
# HERMES_ACTIVE_SESSION_ENABLED=false

# 活跃窗口 TTL(秒),每次插话滑动续期。300 = 5 分钟。
# HERMES_ACTIVE_SESSION_TTL_SEC=300

# 过期清扫 cron 频率(秒)。
# HERMES_ACTIVE_SWEEP_INTERVAL_SEC=30

# MessageBuffer 每群保留的最近消息上限。
# HERMES_BUFFER_PER_GROUP_CAP=200

# MessageBuffer 跨群总容量(LRU 驱逐)。
# HERMES_BUFFER_TOTAL_GROUPS_CAP=50

# ============================================================
# M1 — 反向 MCP 通道 (实验性)
# ============================================================

# 启用后插件起一个本地 MCP server,让 Hermes Agent 主动调用 push_message
# / list_active_sessions / get_recent_messages 等工具。
# 配套需要:
#   1. 跑 `hermes-install-skill` 把 SKILL.md 装到 ~/.hermes/skills/
#   2. 在 ~/.hermes/config.yaml 注册 nonebot-bridge MCP server
# HERMES_MCP_ENABLED=false

# MCP server 绑定地址。默认 loopback (127.0.0.1)。
# 改成监听公网/局域网地址在技术上完全可行,但安全代价:push_message 工具
# 能让 bot 往群里发任意内容,而前端防御只有 Bearer token(明文 HTTP,且
# 与 HERMES_API_KEY 同钥匙)。改之前请上反向代理 + TLS + 来源 IP ACL。
# HERMES_MCP_HOST=127.0.0.1

# MCP server 绑定端口。
# HERMES_MCP_PORT=8643

# get_recent_messages 工具单次返回上限。
# HERMES_MCP_RECENT_LIMIT_MAX=50
